{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/auth/google", "dest": "/api/auth-google.js" },
    { "src": "/auth/google/callback", "dest": "/api/auth-google-cb.js" },
    { "src": "/auth/meta", "dest": "/api/auth-meta.js" },
    { "src": "/auth/meta/callback", "dest": "/api/auth-meta-cb.js" },
    { "src": "/api/gtm/(.*)", "dest": "/api/gtm.js" },
    { "src": "/api/meta/bm/(.*)", "dest": "/api/meta-clients.js" },
    { "src": "/api/meta/pixels/(.*)", "dest": "/api/meta-clients.js" },
    { "src": "/api/meta/insights/(.*)", "dest": "/api/meta-clients.js" },
    { "src": "/api/meta/pixel-quality/(.*)", "dest": "/api/meta-clients.js" },
    { "src": "/api/meta/(.*)", "dest": "/api/meta.js" },
    { "src": "/api/clients(.*)", "dest": "/api/clients.js" },
    { "src": "/api/track", "dest": "/api/tracking.js" },
    { "src": "/api/sync/(.*)", "dest": "/api/sync.js" },
    { "src": "/api/webhooks/(.*)", "dest": "/api/webhooks.js" },
    { "src": "/api/audiences/sync", "dest": "/api/audiences.js" },
    { "src": "/api/alerts/check", "dest": "/api/alerts.js" },
    { "src": "/api/dashboard", "dest": "/api/dashboard.js" },
    { "src": "/api/session", "dest": "/api/session.js" },
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "https://SEU_DOMINIO.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/sync/all",
      "schedule": "0 */6 * * *"
    }
  ]
}
